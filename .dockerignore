# Exclude unnecessary files from Docker build context

# Backend
backend/logs/
backend/media/
backend/staticfiles/
backend/db.sqlite3
backend/.venv/
backend/__pycache__/

# Frontend
frontend/dist/
frontend/node_modules/
frontend/.venv/

# General
.venv/
.git
.gitignore
.github/
__pycache__/
*.py[cod]
*.log
*.tmp
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# But DO include these for Docker build
!frontend/package*.json
!frontend/src/
!frontend/*.config.*
!frontend/tsconfig.json
!frontend/index.html
!backend/requirements.txt
